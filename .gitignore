# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Cargo.lock is committed for the binary so Docker builds are reproducible.
# (This is an application, not a library — the lockfile belongs in git.)

# These are backup files generated by rustfmt
**/*.rs.bk

# Profiling artifact from `cargo run --example alloc_profile` (regenerable)
dhat-heap.json

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Environment variables
.env
.envrc

# Gallery images
public/images/*
!public/images/home/gallery.toml

# Other content
public/content/*
!public/content/config.toml.example

# Image cache
public/cache/
cache/

# MacOS Artifacts
.DS_Store

# Claude
.claude/*
